// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id         String   @id @map("_id")
  nickname   String
  email      String   @unique
  profile    String   @default("기본이미지")
  userCode   String   @unique
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  isKnocked  Boolean  @default(true)
  isAgreed   Boolean  @default(false) // 약관 동의 완료 여부 (필수 약관 모두 동의 시 true)

  buckets   Bucket[]
  moments   Moment[]
  userTerms UserTerm[]
  following Follow[] @relation("UserFollowing")
  followers Follow[] @relation("UserFollowers")

  @@map("user") // MongoDB 컬렉션 이름을 "user"로 지정
}

model Term {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String   @unique
  content   String
  type      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userTerms UserTerm[]

  @@map("term") // MongoDB 컬렉션 이름을 "term"로 지정
}

model UserTerm {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userID    String
  termID    String   @db.ObjectId
  agreed    Boolean  @default(false)
  agreedAt  DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userID], references: [id])
  term Term @relation(fields: [termID], references: [id])

  @@unique([userID, termID])
  @@map("userTerm")
}

model Follow {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  followerID  String
  followingID String
  isFavorite  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  follower  User @relation("UserFollowing", fields: [followerID], references: [id])
  following User @relation("UserFollowers", fields: [followingID], references: [id])

  @@unique([followerID, followingID])
  @@map("follow")
}

model Bucket {
  id             String    @id @default(auto()) @map("_id") @db.ObjectId
  userID         String
  title          String
  category       String[]  @default([])
  thumbnail      String    @default("기본이미지URL")
  totalMoment    Float     @default(0)
  completedCount Float     @default(0)
  isCompleted    Boolean   @default(false)
  isChallenging  Boolean   @default(false)
  startDate      DateTime?
  endDate        DateTime?
  totalCheer     Float     @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user    User     @relation(fields: [userID], references: [id])
  moments Moment[]

  @@map("bucket")
}


model Moment {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  bucketID    String   @db.ObjectId
  userID      String
  momentTitle String
  isCompleted Boolean  @default(false)
  photoUrl    String   @default("")
  startDate   DateTime @default(now())
  endDate     DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  bucket Bucket @relation(fields: [bucketID], references: [id])
  user   User   @relation(fields: [userID], references: [id])

  @@map("moment")
}